// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * - create the database schema
 * - user has (id, username, email, password, root_id,created_at)
 * - folder has (id, name,size,parent_id,created_at)
 * - children has (folder_id,object_id,is_file) // object here refere to file or folder
 * - file has (id, name,url,resource_type,format, size,folder_id,created_at)
 * - refresh_tokens has (id, user_id,token_uuid,hashed_refresh_token,expires_at,created_at)
 * - shared has (object_id,user_id) // object here refere to file or folder
 * - permission has (object_id,type,nested) // object here refere to file or folder
 * // type in [private , shared, public]
 */

/**
 * =========================
 * ENUMS
 * =========================
 */

enum ObjectType {
  file
  folder
}

enum SessionStatus {
  uploading
  merging
  done
  failed
}

enum PermissionRole {
  owner
  editor
  viewer
}

enum Visibility {
  private
  public
  unlisted
}

/**
 * =========================
 * USER
 * =========================
 */

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  email          String   @unique
  hashedPassword String
  createdAt      DateTime @default(now())

  RefreshTokens RefreshTokens[]
  Folders       Folder[]
  Files         File[]
  permissions   Permission[]
}

/**
 * =========================
 * REFRESH TOKENS
 * =========================
 */

model RefreshTokens {
  id                 String   @id @default(uuid())
  userId             String
  tokenUuid          String   @unique
  hashedRefreshToken String   @unique
  expiresAt          DateTime
  createdAt          DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenUuid, userId])
}

/**
 * =========================
 * FOLDER (TREE STRUCTURE)
 * =========================
 */

model Folder {
  id         String     @id @default(uuid())
  parentId   String?
  ownerId    String
  name       String
  size       BigInt     @default(0)
  visibility Visibility @default(private)
  createdAt  DateTime   @default(now())

  User User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[] @relation("FolderTree")

  files File[]

  @@unique([ownerId, parentId, name])
}

/**
 * =========================
 * FILE
 * =========================
 */

model File {
  id           String  @id @default(uuid())
  name         String
  resourceType String?
  mimetype     String
  size         BigInt  @default(0)
  path         String?

  folderId String
  ownerId  String

  totalChunks    Int     @default(0)
  uploadedChunks Int     @default(0)
  isComplete     Boolean @default(false)

  hash       String?
  visibility Visibility @default(private)

  createdAt DateTime @default(now())

  User   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  Folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  chunks         ChunkFile[]
  uploadSessions UploadSession[]
}

/**
 * =========================
 * CHUNKS
 * =========================
 */

model ChunkFile {
  id String @id @default(uuid())

  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  index Int
  size  Int
  path  String

  hash       String?
  uploaded   Boolean   @default(false)
  attempts   Int       @default(0)
  uploadedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([fileId, index])
}

/**
 * =========================
 * UPLOAD SESSION
 * =========================
 */

model UploadSession {
  id String @id @default(uuid())

  fileId String @unique
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  status    SessionStatus @default(uploading) // uploading | merging | done | failed
  createdAt DateTime      @default(now())
}

/**
 * =========================
 * PERMISSION SYSTEM
 * =========================
 */

model Permission {
  id String @id @default(uuid())

  userId String

  objectId   String
  objectType ObjectType

  role PermissionRole

  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, objectId, objectType])
  @@index([objectId, objectType])
}
